FROM node:22-alpine

WORKDIR /app

# Enable pnpm via corepack
RUN corepack enable && corepack prepare pnpm@10.29.3 --activate

# Copy workspace manifests first — layer cache: reinstall only when lockfile changes
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY packages/tsconfig/package.json packages/tsconfig/
COPY packages/core/package.json      packages/core/
COPY packages/ui/package.json        packages/ui/
COPY apps/web/package.json           apps/web/
# prisma/schema.prisma is needed by the apps/web postinstall script (prisma generate)
COPY apps/web/prisma/                apps/web/prisma/

RUN pnpm install --frozen-lockfile

# Copy full source (overridden by volume mount at runtime in docker-compose)
COPY . .

# Next.js needs these to bind correctly inside Docker
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

EXPOSE 3000

# Run only the web app dev server
CMD ["pnpm", "--filter", "@unym/web", "dev"]
