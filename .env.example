# Copy to .env and fill in values

# Database — Vercel Postgres or Neon free tier
DATABASE_URL="postgresql://user:password@host:5432/unym?sslmode=require"

# Sentry — server-side (Next.js API routes, server components)
SENTRY_DSN=""

# Sentry — client-side (browser bundle, must have NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry source maps — needed for production sourcemap uploads (optional at dev)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# BetterAuth
BETTER_AUTH_SECRET=         # Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_URL=            # App URL (e.g., http://localhost:3000 for dev)
GOOGLE_CLIENT_ID=           # Google OAuth client ID
GOOGLE_CLIENT_SECRET=       # Google OAuth client secret
